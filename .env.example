# ---- ANON server configuration ----
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).

# HTTP port the API/WS server listens on
PORT=5000

# Comma-separated list of allowed browser origins (CORS). No trailing slash.
# In production set this to your real frontend origin, e.g. https://anon.example.edu
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Secret used to sign session JWTs. MUST be long & random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-use-a-48-byte-random-hex-string

# Access-token lifetime. Accepts values like 15m, 1h, 2h.
JWT_EXPIRES_IN=1h

# Where uploaded images are written (relative to repo root or absolute).
UPLOAD_DIR=uploads

# Max image upload size in bytes (default 5 MB).
MAX_UPLOAD_BYTES=5242880

# SQLite database file.
DB_FILE=anon.db

# Set to "production" on deployed servers to enable stricter behavior.
NODE_ENV=development

# When behind a TLS-terminating reverse proxy (nginx/Caddy/Cloud LB), set to 1
# so Express trusts X-Forwarded-* headers (needed for correct client IPs & secure cookies).
TRUST_PROXY=0
